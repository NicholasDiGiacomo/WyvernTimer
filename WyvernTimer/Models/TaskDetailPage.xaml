<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WyvernTimer.TaskDetailPage"
             Title="Task Details">

    <ScrollView>
        <VerticalStackLayout Padding="24,36" Spacing="18">

            <Label Text="Task Details"
                   Style="{StaticResource PageTitleStyle}" />

            <Border Stroke="{StaticResource SurfaceBorderColor}"
                    BackgroundColor="{StaticResource SurfaceColor}"
                    StrokeThickness="1"
                    Padding="16"
                    StrokeShape="RoundRectangle 14">

                <VerticalStackLayout Spacing="14">

                    <Label Text="Task Name" Style="{StaticResource SectionHeaderStyle}" />
                    <Entry x:Name="TaskNameEntry"
                           Placeholder="Enter task name" />

                    <Label Text="Description" Style="{StaticResource SectionHeaderStyle}" />
                    <Entry x:Name="TaskDescriptionEntry"
                           Placeholder="Enter task description" />

                    <Button x:Name="SaveChangesButton"
                            Text="Save Changes"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Clicked="OnSaveChangesClicked" />
                </VerticalStackLayout>
            </Border>

            <Border Stroke="{StaticResource SurfaceBorderColor}"
                    BackgroundColor="{StaticResource SurfaceColor}"
                    StrokeThickness="1"
                    Padding="16"
                    StrokeShape="RoundRectangle 14">

                <VerticalStackLayout Spacing="10">
                    <Label Text="Elapsed Time" Style="{StaticResource SectionHeaderStyle}" />

                    <Label x:Name="ElapsedTimeLabel"
                           Text="00:00:00"
                           TextColor="{StaticResource PrimaryTextColor}"
                           FontSize="32"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />

                    <Label Text="Total Recorded Time"
                           Style="{StaticResource SectionHeaderStyle}" />

                    <Label x:Name="TotalTimeLabel"
                           Text="00:00:00"
                           TextColor="{StaticResource AccentColor}"
                           FontSize="22"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />

                    <Label x:Name="TaskStatusLabel"
                           Text="Task is not running."
                           TextColor="{StaticResource SecondaryTextColor}"
                           FontSize="15"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="8">
                <Button x:Name="StartButton"
                        Text="Start Timer"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Clicked="OnStartTimerClicked" />

                <Button x:Name="StopButton"
                        Text="Stop Timer"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Clicked="OnStopTimerClicked" />

                <Button x:Name="DeleteButton"
                        Text="Delete Task"
                        Style="{StaticResource DangerButtonStyle}"
                        Clicked="OnDeleteTaskClicked" />
            </VerticalStackLayout>

            <Label Text="Session Log"
                   Style="{StaticResource SectionHeaderStyle}"
                   Margin="0,6,0,0" />

            <CollectionView x:Name="SessionLogCollectionView"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="{StaticResource SurfaceBorderColor}"
                                BackgroundColor="{StaticResource SurfaceColor}"
                                StrokeThickness="1"
                                Padding="12"
                                Margin="0,5"
                                StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding StartTime, StringFormat='Date: {0:G}'}"
                                       TextColor="{StaticResource PrimaryTextColor}"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding Duration, StringFormat='Duration: {0:hh\\:mm\\:ss}'}"
                                       TextColor="{StaticResource AccentColor}" />
                                <Label Text="{Binding Comment, StringFormat='Comment: {0}'}"
                                       TextColor="{StaticResource SecondaryTextColor}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>