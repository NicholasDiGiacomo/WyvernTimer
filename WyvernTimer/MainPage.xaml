<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WyvernTimer.MainPage"
             Title="Wyvern Timer">

    <Grid Padding="24,36" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">

        <Label Grid.Row="0"
               Text="WyvernTimer"
               Style="{StaticResource PageTitleStyle}" />

        <VerticalStackLayout Grid.Row="1" Spacing="10" Margin="0,20,0,10">
            <Label Text="Create New Task" Style="{StaticResource SectionHeaderStyle}" />

            <Entry x:Name="TaskNameEntry"
                   Placeholder="Task name" />

            <Entry x:Name="TaskDescriptionEntry"
                   Placeholder="Task description" />

            <Button Text="Create Task"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Clicked="OnCreateTaskClicked" />
        </VerticalStackLayout>

        <Label Grid.Row="2"
               Text="Task List"
               Style="{StaticResource SectionHeaderStyle}"
               Margin="0,10,0,10" />

        <CollectionView Grid.Row="4"
                        x:Name="TaskCollectionView"
                        SelectionMode="Single"
                        SelectionChanged="OnTaskSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="{StaticResource SurfaceBorderColor}"
                            BackgroundColor="{StaticResource SurfaceColor}"
                            StrokeThickness="1"
                            Padding="14"
                            Margin="0,6"
                            StrokeShape="RoundRectangle 14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Name}"
                                   TextColor="{StaticResource PrimaryTextColor}"
                                   FontSize="18"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding Description}"
                                   TextColor="{StaticResource SecondaryTextColor}"
                                   FontSize="14" />
                            <Label Text="{Binding DisplayText}"
                                   TextColor="{StaticResource AccentColor}"
                                   FontSize="14" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Grid.Row="5"
               x:Name="TaskStatusLabel"
               Text="Create a task or select one from the list."
               TextColor="{StaticResource SecondaryTextColor}"
               FontSize="14"
               Margin="0,12,0,0" />

    </Grid>
</ContentPage>